#!/usr/bin/env bash
# pocket — control the JORAN Pocket remote terminal tunnel from anywhere.
#
# Usage:
#   pocket              Ensure services up, print + copy URL to clipboard
#   pocket start        Install / (re)kickstart services (safe to re-run)
#   pocket stop         Stop all services
#   pocket restart      Rotate tunnel URL (new URL → auto iMessage if configured)
#   pocket status       Show service state + current URL
#   pocket logs         Tail tunnel log (Ctrl-C to quit)
#   pocket attach       Attach current shell to the shared 'pocket' tmux session
#   pocket url          Print the URL (no clipboard, no checks)
#   pocket install      Re-run the installer (regenerates wrappers + plists)
#   pocket help         Show this help

set -euo pipefail

POCKET_HOME="$HOME/Pocket"
URL_FILE="$POCKET_HOME/current-url.txt"
LOG_DIR="$POCKET_HOME/logs"
TMUX_SESSION="pocket"

# Stamped by setup-services.sh at install time.
SETUP_SCRIPT="__SETUP_SCRIPT__"
REPO_ROOT="__REPO_ROOT__"

TTYD_LABEL="pocket.tmux.ttyd"
TUNNEL_LABEL="pocket.tmux.tunnel"
WATCHER_LABEL="pocket.tmux.watcher"

is_loaded() { launchctl list 2>/dev/null | awk '{print $3}' | grep -qx "$1"; }

ensure_loaded() {
  local need_install=0
  for svc in "$TTYD_LABEL" "$TUNNEL_LABEL" "$WATCHER_LABEL"; do
    is_loaded "$svc" || need_install=1
  done
  if [ "$need_install" = "1" ]; then
    echo "→ some services missing; running installer..."
    [ -f "$SETUP_SCRIPT" ] || { echo "ERROR: installer not found at $SETUP_SCRIPT" >&2; return 1; }
    bash "$SETUP_SCRIPT"
  fi
}

wait_for_url() {
  local tries="${1:-30}"
  for _ in $(seq 1 "$tries"); do
    if [ -s "$URL_FILE" ]; then cat "$URL_FILE"; return 0; fi
    sleep 1
  done
  return 1
}

copy_to_clipboard() {
  command -v pbcopy >/dev/null 2>&1 || return 1
  printf '%s' "$1" | pbcopy
}

cmd="${1:-show}"

case "$cmd" in
  ""|show)
    ensure_loaded
    echo "→ waiting for tunnel URL..."
    if url="$(wait_for_url 30)"; then
      echo
      echo "  🌍  $url"
      echo
      copy_to_clipboard "$url" && echo "  ✓ 已复制到剪贴板（直接粘到 iPhone Safari 即可）"
      if [ -s "$POCKET_HOME/imessage-to.txt" ]; then
        echo "  ✓ iMessage 也会收到新 URL（自动推送）"
      fi
      echo
      AUTH_USER="$(cut -d: -f1 "$POCKET_HOME/auth.txt" 2>/dev/null || echo '?')"
      echo "  🔑 login: $AUTH_USER / (your password)"
    else
      echo "URL 还没就绪。看日志：  pocket logs" >&2
      exit 1
    fi
    ;;

  start|install)
    [ -f "$SETUP_SCRIPT" ] || { echo "ERROR: installer not found at $SETUP_SCRIPT" >&2; exit 1; }
    bash "$SETUP_SCRIPT"
    ;;

  stop)
    for svc in "$WATCHER_LABEL" "$TUNNEL_LABEL" "$TTYD_LABEL"; do
      launchctl bootout "gui/$UID/$svc" 2>/dev/null && echo "stopped: $svc" || echo "(already stopped): $svc"
    done
    ;;

  restart)
    launchctl kickstart -k "gui/$UID/$TUNNEL_LABEL" 2>/dev/null || {
      echo "tunnel not loaded; try:  pocket start" >&2; exit 1;
    }
    echo "→ tunnel restarting; new URL incoming..."
    sleep 2
    if url="$(wait_for_url 30)"; then
      echo
      echo "  🌍  $url"
      copy_to_clipboard "$url" && echo "  ✓ 已复制到剪贴板"
    else
      echo "URL 还没出来；看:  pocket logs" >&2; exit 1
    fi
    ;;

  status)
    echo "Services:"
    for svc in "$TTYD_LABEL" "$TUNNEL_LABEL" "$WATCHER_LABEL"; do
      if is_loaded "$svc"; then
        line="$(launchctl list | awk -v s="$svc" '$3==s {print $1, $2}')"
        echo "  ✓ $svc   [pid/exit: $line]"
      else
        echo "  ✗ $svc   (not loaded)"
      fi
    done
    echo
    if [ -s "$URL_FILE" ]; then echo "Current URL: $(cat "$URL_FILE")"; else echo "Current URL: (not set)"; fi
    ;;

  logs)
    exec tail -F "$LOG_DIR/tunnel.out.log"
    ;;

  attach)
    command -v tmux >/dev/null 2>&1 || { echo "ERROR: tmux not installed" >&2; exit 1; }
    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
      exec tmux attach -t "$TMUX_SESSION"
    else
      echo "tmux session '$TMUX_SESSION' doesn't exist yet — run:  pocket start"; exit 1
    fi
    ;;

  url)
    if [ -s "$URL_FILE" ]; then cat "$URL_FILE"; else echo "(no URL yet — run: pocket start)" >&2; exit 1; fi
    ;;

  help|-h|--help)
    sed -n '2,15p' "$0" | sed 's/^# \{0,1\}//'
    ;;

  *)
    echo "unknown command: $cmd" >&2
    echo "try: pocket help" >&2
    exit 2
    ;;
esac
