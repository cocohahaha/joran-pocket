#!/usr/bin/env bash
# pocket — generate one-shot mobile-web URLs for a shared tmux session.
#
# Core flow:
#   pocket share [--ttl <dur>]   Start SSH tunnel, print + iMessage URL,
#                                optionally auto-stop after <dur> (e.g. 30m, 2h)
#   pocket stop                  Stop the SSH tunnel (URL dies)
#   pocket status                Service state + current URL
#   pocket attach                Attach current shell to the shared tmux session
#   pocket logs                  Tail tunnel log
#   pocket install               Re-run the installer
#   pocket help                  Show this help
#
# The ttyd backend and watcher stay running in the background so `pocket share`
# is fast (<5s). The SSH tunnel is on-demand: each `share` is a fresh link.

set -euo pipefail

POCKET_HOME="$HOME/Pocket"
URL_FILE="$POCKET_HOME/current-url.txt"
LOG_DIR="$POCKET_HOME/logs"
TMUX_SESSION="pocket"
TTL_MARK="$POCKET_HOME/ttl.pid"

# Stamped by setup-services.sh at install time.
SETUP_SCRIPT="__SETUP_SCRIPT__"
REPO_ROOT="__REPO_ROOT__"

TTYD_LABEL="pocket.tmux.ttyd"
TUNNEL_LABEL="pocket.tmux.tunnel"
WATCHER_LABEL="pocket.tmux.watcher"

is_loaded() { launchctl list 2>/dev/null | awk '{print $3}' | grep -qx "$1"; }

ensure_backend() {
  local need_install=0
  for svc in "$TTYD_LABEL" "$WATCHER_LABEL"; do
    is_loaded "$svc" || need_install=1
  done
  if [ "$need_install" = "1" ]; then
    echo "→ backend services missing; running installer..."
    [ -f "$SETUP_SCRIPT" ] || { echo "ERROR: installer not found at $SETUP_SCRIPT" >&2; return 1; }
    bash "$SETUP_SCRIPT"
  fi
}

wait_for_fresh_url() {
  local started="$1" tries="${2:-40}"
  for _ in $(seq 1 "$tries"); do
    if [ -s "$URL_FILE" ]; then
      local mtime
      mtime="$(stat -f %m "$URL_FILE" 2>/dev/null || echo 0)"
      if [ "$mtime" -ge "$started" ]; then cat "$URL_FILE"; return 0; fi
    fi
    sleep 1
  done
  return 1
}

copy_to_clipboard() {
  command -v pbcopy >/dev/null 2>&1 || return 1
  printf '%s' "$1" | pbcopy
}

parse_ttl_seconds() {
  local s="$1"
  case "$s" in
    *s) echo "${s%s}" ;;
    *m) echo "$(( ${s%m} * 60 ))" ;;
    *h) echo "$(( ${s%h} * 3600 ))" ;;
    *)  echo "$s" ;;  # bare number = seconds
  esac
}

schedule_auto_stop() {
  local ttl_sec="$1"
  # Kill any prior auto-stop job
  if [ -s "$TTL_MARK" ]; then
    local old
    old="$(cat "$TTL_MARK" 2>/dev/null || true)"
    [ -n "$old" ] && kill "$old" 2>/dev/null || true
  fi
  ( sleep "$ttl_sec"
    launchctl bootout "gui/$UID/$TUNNEL_LABEL" 2>/dev/null || true
    rm -f "$URL_FILE" "$TTL_MARK"
  ) >/dev/null 2>&1 &
  echo "$!" > "$TTL_MARK"
}

cmd_share() {
  local ttl=""
  while [ $# -gt 0 ]; do
    case "$1" in
      --ttl) ttl="$2"; shift 2 ;;
      --ttl=*) ttl="${1#--ttl=}"; shift ;;
      *) echo "unknown arg: $1" >&2; return 2 ;;
    esac
  done

  ensure_backend

  # Clear stale URL so we know the next one is fresh.
  local share_start; share_start="$(date +%s)"
  : > "$URL_FILE"

  # Kick a fresh tunnel. If already loaded, kickstart re-runs it.
  if is_loaded "$TUNNEL_LABEL"; then
    launchctl kickstart -k "gui/$UID/$TUNNEL_LABEL"
  else
    local plist="$HOME/Library/LaunchAgents/${TUNNEL_LABEL}.plist"
    launchctl bootstrap "gui/$UID" "$plist"
    launchctl kickstart "gui/$UID/$TUNNEL_LABEL"
  fi

  echo "→ opening a new one-shot URL..."
  local url
  if ! url="$(wait_for_fresh_url "$share_start" 40)"; then
    echo "URL 没在 40 秒内出现。看日志：  pocket logs" >&2
    return 1
  fi

  echo
  echo "  🌍  $url"
  echo
  copy_to_clipboard "$url" && echo "  ✓ 已复制到剪贴板"
  if [ -s "$POCKET_HOME/imessage-to.txt" ]; then
    bash "$POCKET_HOME/send-imessage.sh" "🌐 JORAN Pocket：$url" >/dev/null 2>&1 || true
    echo "  ✓ iMessage 已推送到 $(cat "$POCKET_HOME/imessage-to.txt")"
  fi

  if [ -n "$ttl" ]; then
    local ttl_sec; ttl_sec="$(parse_ttl_seconds "$ttl")"
    schedule_auto_stop "$ttl_sec"
    echo "  ⏱  ${ttl} 后自动关闭"
  fi
  echo
  echo "  🔑 Safari 会弹登录框，输安装时设置的账号/密码"
  echo "  ⏹  结束：pocket stop"
}

cmd_stop() {
  if [ -s "$TTL_MARK" ]; then
    local pid; pid="$(cat "$TTL_MARK" 2>/dev/null || true)"
    [ -n "$pid" ] && kill "$pid" 2>/dev/null || true
    rm -f "$TTL_MARK"
  fi
  launchctl bootout "gui/$UID/$TUNNEL_LABEL" 2>/dev/null && echo "stopped tunnel" || echo "(tunnel already stopped)"
  : > "$URL_FILE"
}

cmd_stop_all() {
  cmd_stop
  for svc in "$WATCHER_LABEL" "$TTYD_LABEL"; do
    launchctl bootout "gui/$UID/$svc" 2>/dev/null && echo "stopped: $svc" || echo "(already stopped): $svc"
  done
}

cmd_status() {
  echo "Services:"
  for svc in "$TTYD_LABEL" "$WATCHER_LABEL" "$TUNNEL_LABEL"; do
    if is_loaded "$svc"; then
      line="$(launchctl list | awk -v s="$svc" '$3==s {print $1, $2}')"
      echo "  ✓ $svc   [pid/exit: $line]"
    else
      echo "  ✗ $svc   (not loaded)"
    fi
  done
  echo
  if [ -s "$URL_FILE" ]; then echo "Current URL: $(cat "$URL_FILE")"; else echo "Current URL: (none — run: pocket share)"; fi
}

cmd="${1:-}"; shift || true
case "$cmd" in
  "")
    cat <<'HINT' >&2
pocket 老命令（ttyd + 公网 tunnel 路线）已不再是推荐入口。
新路线（Tailscale + SSH）没有 pocket 命令，直接用 Termius/Blink 连就行。

老命令还留着给你排错用：
  pocket share     强制再起一个 lhr.life URL（不稳定，不推荐）
  pocket stop      停掉老 tunnel
  pocket status    看老服务状态
  pocket help      完整子命令列表

如果你想跑新的 Tailscale 安装路线，在 joran-pocket 仓库目录里跑：
  bash install-tailscale.sh
HINT
    exit 0
    ;;
  share)       cmd_share "$@" ;;
  stop)        cmd_stop ;;
  stop-all)    cmd_stop_all ;;
  status)      cmd_status ;;
  logs)        exec tail -F "$LOG_DIR/tunnel.out.log" ;;
  attach)
    command -v tmux >/dev/null 2>&1 || { echo "ERROR: tmux not installed" >&2; exit 1; }
    if tmux has-session -t "$TMUX_SESSION" 2>/dev/null; then
      exec tmux attach -t "$TMUX_SESSION"
    else
      echo "tmux session '$TMUX_SESSION' 还没开 — 运行: pocket share 先创建"; exit 1
    fi
    ;;
  url)
    if [ -s "$URL_FILE" ]; then cat "$URL_FILE"; else echo "(no URL — run: pocket share)" >&2; exit 1; fi
    ;;
  install|start)
    [ -f "$SETUP_SCRIPT" ] || { echo "ERROR: installer not found at $SETUP_SCRIPT" >&2; exit 1; }
    bash "$SETUP_SCRIPT"
    ;;
  help|-h|--help)
    sed -n '2,16p' "$0" | sed 's/^# \{0,1\}//'
    ;;
  *)
    echo "unknown command: $cmd" >&2
    echo "try: pocket help" >&2
    exit 2
    ;;
esac
